{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs"],
      "project": "scripts/*.mjs",
      "ignoreDependencies": ["better-sqlite3", "@woven-deep/content"]
    },
    "packages/content": {
      "entry": ["src/index.ts", "src/compiler/index.ts", "src/cli.ts"],
      "project": "src/**/*.ts"
    },
    "packages/engine": {
      "entry": ["src/index.ts"],
      "project": "src/**/*.ts"
    },
    "packages/session-core": {
      "entry": ["src/index.ts"],
      "project": "src/**/*.ts",
      "ignoreDependencies": ["@woven-deep/engine", "@woven-deep/content"]
    },
    "apps/web": {
      "entry": ["index.html"],
      "project": "src/**/*.{ts,tsx}",
      "ignore": ["src/ui/components/**"],
      "ignoreDependencies": ["tailwindcss"]
    },
    "apps/server": {
      "entry": ["src/main.ts"],
      "project": "src/**/*.ts"
    }
  }
}
